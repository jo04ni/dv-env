{
  "name": "@deadvault/dv-env",
  "version": "0.2.0",
  "description": "Runtime secret injection CLI for DeadVault",
  "license": "MIT",
  "type": "module",
  "bin": {
    "dv-env": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jo04ni/dv-env.git"
  },
  "homepage": "https://deadvault.xyz",
  "bugs": {
    "url": "https://github.com/jo04ni/dv-env/issues"
  },
  "keywords": [
    "deadvault",
    "secrets",
    "cli",
    "runtime-env",
    "agent",
    "vault",
    "web3"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "validate:env": "node scripts/validate-env.mjs --mode=run",
    "validate:env:issue-token": "node scripts/validate-env.mjs --mode=issue-token",
    "validate:env:worker": "node scripts/validate-env.mjs --mode=worker",
    "smoke:agent-broker": "node examples/agent-broker/smoke.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@deadvault/sdk": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
