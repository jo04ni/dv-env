# DeadVault owner address
DV_OWNER=0xYourOwnerAddress

# DeadVault master password (use runtime secret store in CI/agents)
DV_MASTER_PASSWORD=your-master-password

# Optional for v2-encrypted vaults
DV_WALLET_SIGNATURE=0xYourWalletSignature

# Broker mode shared secret (issuer + worker verify key)
DV_BROKER_SECRET=change-this-to-a-long-random-secret

# Optional broker token for worker mode (usually set at runtime)
DV_BROKER_TOKEN=

# Optional mapping convenience for demo scripts
DV_MAP=OPENAI_API_KEY:OpenAI

# Optional token TTL in seconds for broker issuer scripts
DV_TTL_SECONDS=180

# Optional chain override (base | ethereum | arbitrum | optimism)
DV_CHAIN=base
